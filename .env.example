# Google Cloud service account key JSON file path
# Steps to get this:
# 1. Go to console.cloud.google.com
# 2. Create a project (or select existing)
# 3. Enable "Cloud Vision API" and "Cloud Translation API"
# 4. Go to IAM & Admin > Service Accounts > Create Service Account
# 5. Grant roles: "Cloud Vision API User" and "Cloud Translation API User"
# 6. Create a key (JSON) and download it
# 7. Put the file path below (use forward slashes even on Windows)
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account-key.json

# Port the server runs on (default: 3000)
PORT=3000

# Usage limits
PAGE_LIMIT=
GLOBAL_DAILY_LIMIT=
IP_RATE_LIMIT=

# Admin stats page key — set a strong secret value
ADMIN_KEY=

# Contact email shown to users who exceed their quota
CONTACT_EMAIL=
